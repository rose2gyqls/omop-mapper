# Copy this file to .env and fill in the values locally.
# Do not commit your real .env file.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini-2024-07-18

ES_SERVER_HOST=
ES_SERVER_PORT=9200
ES_SERVER_USERNAME=
ES_SERVER_PASSWORD=
ES_USE_SSL=false

# Optional: only needed if you run postgres-based indexing locally.
PG_HOST=
PG_PORT=5432
PG_DBNAME=
PG_USER=
PG_PASSWORD=
